___SANDBOXED_JS_FOR_SERVER___

// === Supermetrics Data Activation — Server Tag ===
// Handles URL-based event forwarding and server-side cookie generation
const logToConsole       = require('logToConsole');
const getEventData       = require('getEventData');
const sendHttpRequest    = require('sendHttpRequest');
const encodeUriComponent = require('encodeUriComponent');
const setCookie          = require('setCookie');
const makeString         = require('makeString');
const makeInteger        = require('makeInteger');

const SM_TRACKING_URL = 'https://t.svtrd.com/';

// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

function appendObjToUrl(url, obj) {
  for (var key in obj) {
    var val = obj[key];
    if (val !== null && val !== undefined && val !== '') {
      url += '&cup=' + encodeUriComponent(key) + '%3A' + encodeUriComponent(val);
    }
  }
  return url;
}

function appendTableToUrl(url, tableArr) {
  for (var i = 0; i < tableArr.length; i++) {
    var prop = tableArr[i];
    if (prop.name && prop.value !== null && prop.value !== undefined && prop.value !== '') {
      url += '&cup=' + encodeUriComponent(prop.name) + '%3A' + encodeUriComponent(prop.value);
    }
  }
  return url;
}

function buildBaseUrl(siteId, trackID, params) {
  var url = SM_TRACKING_URL;
  url = url.charAt(url.length - 1) === '/' ? url.slice(0, -1) : url;
  url += '/t-' + encodeUriComponent(siteId) + '?i=' + encodeUriComponent(trackID);

  for (var key in params) {
    if (params[key] !== null && params[key] !== undefined) {
      url += '&' + key + '=' + encodeUriComponent(params[key]);
    }
  }
  return url;
}

function sendGetRequest(url) {
  return sendHttpRequest(url, {method: 'GET', timeout: 5000});
}

function handleResponse(result) {
  if (result && result.statusCode >= 200 && result.statusCode < 300) {
    logToConsole('[SMDA Server Tag] Success:', result.statusCode);
    data.gtmOnSuccess();
  } else {
    logToConsole('[SMDA Server Tag] Failed:', result ? result.statusCode : 'No Response');
    data.gtmOnFailure();
  }
}

function handleError(error) {
  logToConsole('[SMDA Server Tag] Error:', error);
  data.gtmOnFailure();
}

// ============================================================================
// 1. EXTRACT CORE PARAMETERS
// ============================================================================
const dataSource  = data.dataSource;

// ============================================================================
// 2. DEDICATED COOKIE MANAGEMENT MODE
// ============================================================================
if (dataSource === 'server_cookie') {
  const uuid          = getEventData('x_smda_uuid');
  const setCookieFlag = getEventData('x_smda_set_cookie');
  const cookieName    = getEventData('x_smda_cookie_name') || '_svtri';

  if (!uuid || setCookieFlag === 'false') {
    logToConsole('[SMDA Server Tag] No UUID to set, or set_cookie flag is false.');
    return data.gtmOnSuccess(); // Graceful exit if no cookie needs to be set
  }

  const domain = data.cookieDomain ? makeString(data.cookieDomain) : '';
  const maxAge = data.cookieMaxAge ? makeInteger(data.cookieMaxAge) : 34560000;

  if (!domain) {
    logToConsole('[SMDA Server Tag] Missing required core field: Cookie Domain.');
    return data.gtmOnFailure();
  }
  
  let options = {
    path: '/',
    secure: true,
    sameSite: 'Lax',
    'max-age': maxAge
  };
  if (domain) options.domain = domain;

  logToConsole('[SMDA Server Tag] Setting Cookie', cookieName, '=', uuid);
  setCookie(cookieName, makeString(uuid), options, false);
  
  return data.gtmOnSuccess(); // Stop execution here for the cookie tag
}

// ============================================================================
// 3. BUILD & DISPATCH TRACKING REQUESTS
// ============================================================================
const siteId  = data.siteId || getEventData('x_smda_site_id') || '';
const trackId = data.trackId || getEventData('x_smda_uuid') || '';

if (!siteId || !trackId) {
  logToConsole('[SMDA Server Tag] Missing required core fields (Site ID or Track ID).');
  return data.gtmOnFailure();
}

// --- A. INHERIT FROM CLIENT ---
if (dataSource === 'inherit') {
  const inheritType = getEventData('x_smda_type');
  const props = getEventData('x_smda_properties') || {};

  if (inheritType === 'engagement') {
    var url = buildBaseUrl(siteId, trackId, { e: 'true', et: getEventData('event_name') });
    url = appendObjToUrl(url, props);
    sendGetRequest(url).then(handleResponse).catch(handleError);

  } else if (inheritType === 'fact') {
    var ttl = props.ttl ? makeInteger(props.ttl) : 86400;
    var cleanProps = {};
    for (var key in props) {
      if (key !== 'ttl') cleanProps[key] = props[key];
    }
    var url = buildBaseUrl(siteId, trackId, { f: 'true', ft: getEventData('event_name'), fttl: ttl });
    url = appendObjToUrl(url, cleanProps);
    sendGetRequest(url).then(handleResponse).catch(handleError);

  } else if (inheritType === 'mapping') {
    var partnerType = props.partnerType || '';
    var partnerId = props.partnerId || '';
    var mergeFlag = props.merge === '1' ? '1' : '0';

    if (!partnerType || !partnerId) {
      logToConsole('[SMDA Server Tag] Inherited mapping missing partnerType or partnerId.');
      return data.gtmOnFailure();
    }

    var url = SM_TRACKING_URL + 'syncResponse?ca_site=' + encodeUriComponent(siteId) +
              '&ca_partner=' + encodeUriComponent(partnerType) +
              '&ca_cookie=' + encodeUriComponent(trackId) +
              '&ca_read=pid' +
              '&pid=' + encodeUriComponent(partnerId) +
              '&ca_merge=' + mergeFlag;
    sendGetRequest(url).then(handleResponse).catch(handleError);
  }
}

// --- B. MANUAL CONFIGURATION ---
else if (dataSource === 'manual') {
  const manualType = data.SelectTagType;

  if (manualType === 'type_engagement') {
    var engagementName = '' + (data.engagementName || '');
    var engagementProperties = data.engagementProperties || [];

    if (!engagementName) {
      logToConsole('[SMDA Server Tag] Missing required field: engagementName.');
      return data.gtmOnFailure();
    }

    var url = buildBaseUrl(siteId, trackId, { e: 'true', et: engagementName });
    url = appendTableToUrl(url, engagementProperties);
    sendGetRequest(url).then(handleResponse).catch(handleError);

  } else if (manualType === 'type_fact') {
    var factName = '' + (data.factName || '');
    var factTtl = data.factTtl ? makeInteger(data.factTtl) : 86400;
    var factProperties = data.factProperties || [];

    if (!factName) {
      logToConsole('[SMDA Server Tag] Missing required field: factName.');
      return data.gtmOnFailure();
    }

    var url = buildBaseUrl(siteId, trackId, { f: 'true', ft: factName, fttl: factTtl });
    url = appendTableToUrl(url, factProperties);
    sendGetRequest(url).then(handleResponse).catch(handleError);

  } else if (manualType === 'type_mapping') {
    var partnerType = '' + (data.partnerType || '');
    var partnerId = '' + (data.partnerId || '');
    var mergeFlag = data.merge ? '1' : '0';

    if (!partnerType || !partnerId) {
      logToConsole('[SMDA Server Tag] Missing required field(s): partnerType or partnerId.');
      return data.gtmOnFailure();
    }

    var url = SM_TRACKING_URL + 'syncResponse?ca_site=' + encodeUriComponent(siteId) +
              '&ca_partner=' + encodeUriComponent(partnerType) +
              '&ca_cookie=' + encodeUriComponent(trackId) +
              '&ca_read=pid' +
              '&pid=' + encodeUriComponent(partnerId) +
              '&ca_merge=' + mergeFlag;
    sendGetRequest(url).then(handleResponse).catch(handleError);
  }
}

// --- C. GA4 E-COMMERCE MAPPING ---
else if (dataSource === 'ga4_mapping') {
  var eventName = getEventData('event_name');

  var supportedEvents = [
    'view_item', 'add_to_wishlist', 'add_to_cart', 'remove_from_cart',
    'view_cart', 'begin_checkout', 'purchase'
  ];

  var isSupported = false;
  for (var n = 0; n < supportedEvents.length; n++) {
    if (supportedEvents[n] === eventName) { isSupported = true; break; }
  }

  var items = getEventData('items') || [];

  if (!isSupported || items.length === 0) {
    logToConsole('[SMDA Server Tag] Unsupported GA4 event or empty items array. Skipping.');
    return data.gtmOnFailure();
  }

  var hasSummary = (eventName === 'purchase' || eventName === 'view_cart' || eventName === 'begin_checkout');

  // Handle Order Summary for purchase, view_cart, begin_checkout
  if (hasSummary) {
    var runningTotal = 0;
    var categoryStr = '|';

    for (var j = 0; j < items.length; j++) {
      runningTotal += items[j].price || 0;
      var cat = (items[j].item_category || '').split('|').join('-');
      if (cat && categoryStr.indexOf('|' + cat + '|') === -1) {
        categoryStr += cat + '|';
      }
    }

    var summaryProps = {};
    var transactionId = getEventData('transaction_id');
    var value = getEventData('value');
    var currency = getEventData('currency');
    var coupon = getEventData('coupon');
    var orderIsFirst = getEventData('order_is_first');
    var tax = getEventData('tax');
    var shipping = getEventData('shipping');

    summaryProps.o_item_count = items.length;
    summaryProps.o_categories = categoryStr;
    summaryProps.o_avg_price = items.length > 0 ? (runningTotal / items.length) : 0;
    if (currency) summaryProps.o_currency = currency;
    if (transactionId) summaryProps.o_id = transactionId;
    if (value != null) summaryProps.o_total = value;
    if (coupon) summaryProps.o_coupon = coupon;
    if (orderIsFirst != null) summaryProps.o_is_first = orderIsFirst;
    if (tax != null) summaryProps.o_tax = tax;
    if (shipping != null) summaryProps.o_shipping = shipping;

    var summaryUrl = buildBaseUrl(siteId, trackId, { e: 'true', et: eventName + '_summary' });
    summaryUrl = appendObjToUrl(summaryUrl, summaryProps);
    sendGetRequest(summaryUrl);
  }

  // Handle Individual Items
  var targetEvent = hasSummary ? eventName + '_item_details' : eventName;
  for (var i = 0; i < items.length; i++) {
    var item = items[i];
    var isLast = (i === items.length - 1);

    var itemProps = {
      i_id: item.item_id,
      i_name: item.item_name,
      i_category: (item.item_category || '').split('|').join('-'),
      i_price: item.price,
      i_quantity: item.quantity || 1,
      i_brand: item.item_brand,
      i_variant: item.item_variant
    };

    if (hasSummary) {
      if (getEventData('transaction_id')) itemProps.o_id = getEventData('transaction_id');
      if (getEventData('value') != null) itemProps.o_total = getEventData('value');
      if (getEventData('currency')) itemProps.o_currency = getEventData('currency');
      itemProps.o_item_count = items.length;
      itemProps.i_line_total = (item.price || 0) * (item.quantity || 1);
      if (item.coupon) itemProps.i_coupon = item.coupon;
    }

    var itemUrl = buildBaseUrl(siteId, trackId, { e: 'true', et: targetEvent });
    itemUrl = appendObjToUrl(itemUrl, itemProps);

    if (isLast) {
      sendGetRequest(itemUrl).then(handleResponse).catch(handleError);
    } else {
      sendGetRequest(itemUrl);
    }
  }
}


