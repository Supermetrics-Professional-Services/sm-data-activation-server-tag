___SANDBOXED_JS_FOR_SERVER___

// === Supermetrics Data Activation — Server Tag ===
// Handles REST API event forwarding and server-side cookie generation
const logToConsole       = require('logToConsole');
const getEventData       = require('getEventData');
const sendHttpRequest    = require('sendHttpRequest');
const JSON               = require('JSON');
const encodeUriComponent = require('encodeUriComponent');
const setCookie          = require('setCookie');
const makeString         = require('makeString');
const makeInteger        = require('makeInteger');
const makeTableMap       = require('makeTableMap');
const toBase64           = require('toBase64');

// ============================================================================
// 1. EXTRACT CORE PARAMETERS
// ============================================================================
const dataSource  = data.dataSource;

// ============================================================================
// 2. DEDICATED COOKIE MANAGEMENT MODE
// ============================================================================
if (dataSource === 'server_cookie') {
  const uuid          = getEventData('x_smda_uuid');
  const setCookieFlag = getEventData('x_smda_set_cookie');
  const cookieName    = getEventData('x_smda_cookie_name') || '_svtri';

  if (!uuid || setCookieFlag === 'false') {
    logToConsole('[SMDA Server Tag] No UUID to set, or set_cookie flag is false.');
    return data.gtmOnSuccess(); // Graceful exit if no cookie needs to be set
  }

  const domain = data.cookieDomain ? makeString(data.cookieDomain) : '';
  const maxAge = data.cookieMaxAge ? makeInteger(data.cookieMaxAge) : 34560000;

  if (!domain) {
    logToConsole('[SMDA Server Tag] Missing required core field: Cookie Domain.');
    return data.gtmOnFailure();
  }
  
  let options = {
    path: '/',
    secure: true,
    sameSite: 'Lax',
    'max-age': maxAge
  };
  if (domain) options.domain = domain;

  logToConsole('[SMDA Server Tag] Setting Cookie', cookieName, '=', uuid);
  setCookie(cookieName, makeString(uuid), options, false);
  
  return data.gtmOnSuccess(); // Stop execution here for the cookie tag
}

// ============================================================================
// 3. PARSE PAYLOAD & DETERMINE API ROUTE (For API modes only)
// ============================================================================
const apiUsername = data.apiUsername || '';
const apiPassword = data.apiPassword || '';
const siteId      = data.siteId || getEventData('x_smda_site_id') || '';
const trackId     = data.trackId || getEventData('x_smda_uuid') || '';

if (!apiUsername || !apiPassword || !siteId || !trackId) {
  logToConsole('[SMDA Server Tag] Missing required core fields (Username, Password, Site ID, or Track ID).');
  return data.gtmOnFailure();
}  

let apiRoute = ''; // Will be 'engagement', 'fact', or 'mapping'
let payloadItems = []; 
let mappingMergeType = 'NO_MERGE'; // Specific to the mapping route

// --- A. INHERIT FROM CLIENT ---
if (dataSource === 'inherit') {
  apiRoute = getEventData('x_smda_type'); 
  const props = getEventData('x_smda_properties') || {};
  
  if (apiRoute === 'engagement') {
    payloadItems.push({
      interactionType: "engagement",
      type: getEventData('event_name'),
      variables: props
    });
  } else if (apiRoute === 'fact') {
    let ttl = props.ttl;
    
    // Sandbox-safe way to remove 'ttl'
    let cleanProps = {};
    for (let key in props) {
      if (key !== 'ttl') {
        cleanProps[key] = props[key];
      }
    }
    
    payloadItems.push({
      factName: getEventData('event_name'),
      factTtl: ttl ? makeInteger(ttl) : 86400,
      properties: cleanProps
    });
  } else if (apiRoute === 'mapping') {
    payloadItems.push({
      partnerType: props.partnerType,
      partnerId: props.partnerId
    });
    mappingMergeType = props.merge === '1' ? 'SITE' : 'NO_MERGE';
  }
}

// --- B. MANUAL CONFIGURATION ---
else if (dataSource === 'manual') {
  const manualType = data.SelectTagType;

  if (manualType === 'type_engagement') {
    apiRoute = 'engagement';
    payloadItems.push({
      interactionType: "engagement",
      type: data.engagementName,
      variables: data.engagementProperties ? makeTableMap(data.engagementProperties, 'name', 'value') : {}
    });
  } else if (manualType === 'type_fact') {
    apiRoute = 'fact';
    payloadItems.push({
      factName: data.factName,
      factTtl: data.factTtl ? makeInteger(data.factTtl) : 86400,
      properties: data.factProperties ? makeTableMap(data.factProperties, 'name', 'value') : {}
    });
  } else if (manualType === 'type_mapping') {
    apiRoute = 'mapping';
    payloadItems.push({
      partnerType: data.partnerType,
      partnerId: data.partnerId
    });
    mappingMergeType = data.merge ? 'SITE' : 'NO_MERGE';
  }
}

// --- C. GA4 E-COMMERCE MAPPING ---
else if (dataSource === 'ga4_mapping') {
  const eventName = getEventData('event_name');
  
  // 1. Supported Events Whitelist Check
  const supportedEvents = [
    'view_item', 'add_to_wishlist', 'add_to_cart', 'remove_from_cart',
    'view_cart', 'begin_checkout', 'purchase'
  ];
  
  let isSupported = false;
  for (let n = 0; n < supportedEvents.length; n++) {
    if (supportedEvents[n] === eventName) { 
      isSupported = true; 
      break; 
    }
  }

  const items = getEventData('items') || [];

  // 2. Validation: Halt if unsupported event or empty items array
  if (!isSupported || items.length === 0) {
    logToConsole('[SMDA Server Tag] Unsupported GA4 event or empty items array. Skipping.');
    return data.gtmOnFailure();
  }

  apiRoute = 'engagement'; // E-commerce events are always engagements
  const isPurchase = eventName === 'purchase';

  // 3. Handle Order Summary (if purchase)
  if (isPurchase) {
    let runningTotal = 0;
    let categoryStr = '';
    
    for (let j = 0; j < items.length; j++) {
      let item = items[j];
      runningTotal += item.price || 0;
      
      // Sanitize item category to avoid pipe conflicts
      let cat = (item.item_category || '').split('|').join('-');
      if (cat && categoryStr.indexOf('|' + cat + '|') === -1) {
        categoryStr += cat + '|';
      }
    }

    payloadItems.push({
      interactionType: "engagement",
      type: "purchase_summary",
      variables: {
        o_id: getEventData('transaction_id'),
        o_total: getEventData('value'),
        o_currency: getEventData('currency'),
        o_item_count: items.length,
        o_coupon: getEventData('coupon'),
        o_categories: '|' + categoryStr, // Exact parity with Web Tag format
        o_is_first: getEventData('order_is_first'), // Added missing parameter
        o_avg_price: items.length > 0 ? (runningTotal / items.length) : 0,
        o_tax: getEventData('tax'),
        o_shipping: getEventData('shipping')
      }
    });
  }

  // 4. Handle Individual Items
  const targetEvent = isPurchase ? 'purchase_item_detail' : eventName;
  for (let i = 0; i < items.length; i++) {
    let item = items[i];
    let itemVars = {
      i_id: item.item_id,
      i_name: item.item_name,
      i_category: (item.item_category || '').split('|').join('-'), // Apply sanitization here too
      i_price: item.price,
      i_quantity: item.quantity || 1,
      i_brand: item.item_brand,
      i_variant: item.item_variant
    };

    if (isPurchase) {
      itemVars.o_id = getEventData('transaction_id');
      itemVars.o_currency = getEventData('currency');
      itemVars.i_line_total = (item.price || 0) * (item.quantity || 1);
      itemVars.i_coupon = item.coupon;
    }

    payloadItems.push({
      interactionType: "engagement",
      type: targetEvent,
      variables: itemVars
    });
  }
}

// ============================================================================
// 4. CONSTRUCT FINAL URL & DISPATCH REST API REQUEST
// ============================================================================
if (payloadItems.length === 0 || !apiRoute) {
  logToConsole('[SMDA Server Tag] No valid items generated or unknown route. Skipping API call.');
  return data.gtmOnSuccess(); 
}

let apiUrl = "https://api.relay42.com/v1/site-" + encodeUriComponent(siteId) + "/profiles/42/";
let finalPayloadString = "";

// Format the URL and Payload structure based on the specific route
if (apiRoute === 'engagement') {
  apiUrl += "interactions?partnerId=" + encodeUriComponent(trackId);
  finalPayloadString = JSON.stringify({ interactions: payloadItems });
  
} else if (apiRoute === 'fact') {
  apiUrl += "facts?forceInsert=true&partnerId=" + encodeUriComponent(trackId);
  finalPayloadString = JSON.stringify(payloadItems);
  
} else if (apiRoute === 'mapping') {
  apiUrl += "mappings?partnerId=" + encodeUriComponent(trackId) + "&mergeType=" + mappingMergeType;
  finalPayloadString = JSON.stringify(payloadItems);
}

// Encode credentials to Base64
const encodedAuth = toBase64( apiUsername + ':' + apiPassword );

const headers = {
  "Content-Type": "application/json",
  "Authorization": "Basic " + encodedAuth
};

logToConsole('[SMDA Server Tag] Sending Request:', apiUrl);
logToConsole('[SMDA Server Tag] Payload:', finalPayloadString);

sendHttpRequest(apiUrl, {
  headers: headers,
  method: "POST",
  timeout: 1000
}, finalPayloadString)
.then((result) => {
  if (result && result.statusCode >= 200 && result.statusCode < 300) {
    logToConsole("[SMDA Server Tag] Success:", result.statusCode);
    data.gtmOnSuccess();
  } else {
    logToConsole("[SMDA Server Tag] Failed:", result ? result.statusCode : 'No Response');
    data.gtmOnFailure();
  }
})
.catch((error) => {
  logToConsole("[SMDA Server Tag] Error:", error);
  data.gtmOnFailure();
});


